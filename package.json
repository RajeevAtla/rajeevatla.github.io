{
	"name": "new-website",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bunx --bun vite dev",
		"build": "bunx --bun vite build",
		"preview": "bunx --bun vite preview",
		"prepare": "bunx --bun svelte-kit sync || echo ''",
		"check": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json --watch",
		"biome:check": "bunx --bun biome ci src postcss.config.cjs svelte.config.js tailwind.config.ts vite.config.ts",
		"biome:format": "bunx --bun biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/postcss": "^4.3.2",
		"@tailwindcss/vite": "^4.3.2",
		"postcss": "^8.5.16",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.3"
	},
	"dependencies": {
		"daisyui": "^5.6.13",
		"rollup": "^4.62.2"
	}
}
